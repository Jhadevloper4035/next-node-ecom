# Production environment for Docker Compose (backend)
# Copy to .env.production and set real secrets + your real domain/origins.

NODE_ENV=production
PORT=5000
APP_NAME=NextNodeEcom
API_PREFIX=/api/v1

FRONTEND_URL=https://your-domain.com
CORS_ORIGIN=https://your-domain.com
CORS_CREDENTIALS=true

JWT_ACCESS_SECRET=replace_with_very_long_random_string_access
JWT_REFRESH_SECRET=replace_with_very_long_random_string_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

COOKIE_NAME=refreshToken
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
COOKIE_PATH=/api/v1/auth

# In production set real SMTP credentials:
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
