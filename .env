# ─────────────────────────────────────────────────────────────────────────────
#  .env.example — copy this to .env and fill in your values
#
#  NOTE: When running via Docker Compose, the following are automatically
#  overridden by docker-compose.yml and do NOT need to be set here:
#    MONGODB_URI, REDIS_URL, SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS
#
#  You MUST set at minimum:
#    JWT_ACCESS_SECRET, JWT_REFRESH_SECRET
#  Generate with:  openssl rand -hex 64
# ─────────────────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_NAME=NodeAuthMVC
API_PREFIX=/api/v1

# URL of your frontend — used to build password-reset links in emails.
FRONTEND_URL=http://localhost:3000

# ── Database ───────────────────────────────────────────────────────────────────
# Used when running locally WITHOUT Docker. Docker Compose overrides this.
MONGODB_URI=mongodb://127.0.0.1:27017/node_auth_mvc

# ── Redis ──────────────────────────────────────────────────────────────────────
# Optional. Enables cluster-safe rate limiting. Docker Compose sets this automatically.
# For local non-Docker use, install redis locally and uncomment:
# REDIS_URL=redis://127.0.0.1:6379

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=c056fb456681c347d66ffc1eb4ea56417437bd3f845520f70e916b7134b08305
JWT_REFRESH_SECRET=09c2a17ddf0b3a9f5fcbf257852858a1ccac5d8366028310c3e646357d8c6ad2
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Cookie ─────────────────────────────────────────────────────────────────────
COOKIE_NAME=refreshToken
COOKIE_SECURE=false          # set to true in production (requires HTTPS)
COOKIE_SAMESITE=lax          # lax | strict | none
COOKIE_DOMAIN=
COOKIE_PATH=/api/v1/auth

# ── OTP ────────────────────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10
OTP_MAX_REQUESTS=3
OTP_WINDOW_MINUTES=15
OTP_RESEND_COOLDOWN_SECONDS=60

# ── Auth throttling ────────────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=8
LOGIN_WINDOW_MINUTES=15
OTP_VERIFY_MAX_ATTEMPTS=8
OTP_VERIFY_WINDOW_MINUTES=15

# ── Mail (SMTP) ────────────────────────────────────────────────────────────────
# Docker Compose points these at Mailpit automatically.
# For production, set these to your real SMTP provider (SendGrid, SES, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=jhanavrojlookout@gmail.com
SMTP_PASS=fubh dnzr vyjr wonk
MAIL_FROM="NodeAuthMVC <no-reply@example.com>"

# ── Behaviour flags ────────────────────────────────────────────────────────────
RETURN_REFRESH_TOKEN_IN_BODY=false
TRUST_PROXY=false            # set to true behind Nginx / load balancer
