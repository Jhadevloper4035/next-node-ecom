{
  "name": "node-auth-mvc",
  "version": "1.0.0",
  "description": "Production-ready authentication & authorization system (Express + MongoDB) with email OTP verification, JWT access/refresh token rotation with reuse detection, RBAC, and strict MVC.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix"
  },
  "keywords": [
    "express",
    "mongodb",
    "mongoose",
    "jwt",
    "otp",
    "nodemailer",
    "rbac"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.1",
    "nodemailer": "^6.9.14",
    "xss": "^1.0.15"
  },
  "optionalDependencies": {
    "redis": "^4.7.0",
    "rate-limit-redis": "^4.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "eslint": "^9.0.0"
  }
}
